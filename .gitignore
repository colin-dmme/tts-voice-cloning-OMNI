# Python cache and local tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local virtual environments
.venv/
venv/
env/
engines/*/.venv/
engines/*/vendor/
engines/*/pretrained/

# Build, obfuscation, and release outputs
build/
dist/
dist_portable/
release/
releases/
*.zip
*.7z
*.tar.gz

# Runtime caches and downloaded model assets
.hf_cache/
models/

# App runtime data
outputs/
logs/
voices/
config/ui_tkinter.json
config/storage.local.yaml
config/file_queue.sqlite3
config/file_queue.sqlite3-shm
config/file_queue.sqlite3-wal

# Git-backed portable user state lives in user_state/ and is intentionally tracked.
!user_state/
!user_state/**

# Local license secrets and generated customer licenses
secrets/
config/license_private_key.pem
*.license-private.pem
license.json
*license*.json

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
